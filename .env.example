# Copy to .env and fill the required values. Never commit .env.

# --- Required ---
OPENAI_API_KEY=
GITHUB_TOKEN=
REPO_ALLOWLIST=https://github.com/owner/repo

# --- Explicit choice ---
OPENAI_MODEL=gpt-5.2

# --- Optional (defaults shown; uncomment to override) ---
# GITHUB_API_URL=https://api.github.com
# WORKSPACE_ROOT=./workspaces
# MAX_FIX_ATTEMPTS=2
# CONTEXT_TOKEN_BUDGET=60000
# CONTEXT_TOP_N_FILES=12
# MAX_CHANGED_FILES=8
# LOG_LEVEL=INFO
# AGENT_GIT_NAME=AI Development Agent
# AGENT_GIT_EMAIL=ai-agent@users.noreply.github.com
# TEST_SANDBOX=docker   # run the target repo's tests inside an isolated Docker container
# Token pricing for the execution report's costUsd (USD per 1M tokens). Defaults are GPT-5.2 list
# prices; override if you switch models. See https://platform.openai.com/docs/pricing
# OPENAI_INPUT_COST_PER_1M=1.75
# OPENAI_OUTPUT_COST_PER_1M=14.0
